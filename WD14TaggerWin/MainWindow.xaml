<Window x:Class="WD14TaggerWin.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:WD14TaggerWin"
        mc:Ignorable="d"
        Title="WD14TaggerWin" Height="793" Width="882" Loaded="Window_Loaded" SizeChanged="Window_SizeChanged" AllowDrop="True" PreviewDragOver="Window_PreviewDragOver" PreviewDrop="Window_PreviewDrop" Closing="Window_Closing" WindowState="Minimized">
    <Grid>
        <Grid.LayoutTransform>
            <ScaleTransform x:Name="Scale"/>
        </Grid.LayoutTransform>
        <Grid Height="42" VerticalAlignment="Top" Cursor="">
            <DockPanel HorizontalAlignment="Stretch">
                <Button DockPanel.Dock="Left"  VerticalAlignment="Stretch" Width="42" Click="Button_Click_Interogate" Cursor="Hand" BorderBrush="Black" ToolTip="ロードしてる画像のタグを推論します。">
                    <Button.Background>
                        <ImageBrush ImageSource="/Resources/tag_icon.png"/>
                    </Button.Background>
                </Button>
                <ComboBox DockPanel.Dock="Left" Width="180" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" VerticalContentAlignment="Center" Name="interrogatorList" IsReadOnly="True" Cursor="Hand"/>
                <StackPanel DockPanel.Dock="Left" Width="299" Orientation="Horizontal">
                    <Label Content="精度" VerticalContentAlignment="Center"/>
                    <Slider Width="192" Cursor="Hand" VerticalContentAlignment="Center" VerticalAlignment="Center" ValueChanged="Slider_ValueChanged" MouseWheel="Threshold_MouseWheel" Name="accuracySlider" SmallChange="2" Maximum="1" LargeChange="0.1" TickFrequency="0.01"/>
                    <TextBox HorizontalAlignment="Left" TextWrapping="Wrap" Text="0" VerticalAlignment="Stretch" Width="70" VerticalContentAlignment="Center" HorizontalContentAlignment="Center" TextChanged="TextBox_TextChanged" Name="accuracyTextBox" GotFocus="accuracyTextBox_GotFocus" PreviewMouseLeftButtonDown="accuracyTextBox_PreviewMouseLeftButtonDown" MouseWheel="Threshold_MouseWheel" AllowDrop="True" Cursor=""/>
                </StackPanel>
                <Button DockPanel.Dock="Left"  VerticalAlignment="Stretch" Width="42" Click="Button_Click_Free" Cursor="Hand" BorderBrush="Black" ToolTip="メモリ上のモデルを開放します。">
                    <Button.Background>
                        <ImageBrush ImageSource="/Resources/trashbox.png"/>
                    </Button.Background>
                </Button>

                <Button DockPanel.Dock="Right" VerticalAlignment="Stretch" Width="42" Click="Button_Click_Config" Cursor="Hand" BorderBrush="Black" ToolTip="設定画面を開きます。" HorizontalAlignment="Right">
                    <Button.Background>
                        <ImageBrush ImageSource="/Resources/Config.png"/>
                    </Button.Background>
                </Button>
                <Button DockPanel.Dock="Right" VerticalAlignment="Stretch" Width="42" Click="Button_Click_Copyright" Cursor="Hand" BorderBrush="Black" ToolTip="権利表示" HorizontalAlignment="Right">
                    <Button.Background>
                        <ImageBrush ImageSource="/Resources/Copyright.png"/>
                    </Button.Background>
                </Button>
            </DockPanel>
        </Grid>
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition/>
            </Grid.ColumnDefinitions>
            <Grid Grid.Column="0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="0.6*"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="0.4*"/>
                </Grid.RowDefinitions>
                <Button Grid.Row="0" BorderBrush="Black" BorderThickness="1,1,1,1" Margin="10,57,0,10" Background="Transparent" Click="Button_Click" Cursor="Hand" >
                    <Image IsHitTestVisible="True"  Name="sourceImage" />
                </Button>
                <GridSplitter Grid.Row="1" Width="100" Margin="0,5,0,0" HorizontalAlignment="Stretch" Height="5" Cursor="SizeNS"/>
                <Grid Grid.Row="2" >
                    <local:ImageInfoPrompt x:Name="ImageInfo" Margin="10,10,0,10" />
                </Grid>
            </Grid>
            <GridSplitter Grid.Column="1" Height="100" Margin="10,0,0,0" HorizontalAlignment="Center" Width="5"/>
            <Grid Grid.Column="2" Cursor="" >
                <Grid.RowDefinitions>
                    <RowDefinition Height="0.3*"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="0.7*"/>
                </Grid.RowDefinitions>
                <Grid Grid.Row="0" Margin="10,57,10,10" >
                    <Grid.RowDefinitions>
                        <RowDefinition/>
                    </Grid.RowDefinitions>
                    <ComboBox Name="categoryList" IsReadOnly="True" VerticalAlignment="Top" SelectionChanged="categoryList_SelectionChanged" Height="22"/>
                    <TextBox TextWrapping="Wrap" VerticalScrollBarVisibility="Auto" Name="resultTextBox" Margin="0,22,30,0" />
                    <Button Margin="0,22,0,0" Height="30" VerticalAlignment="Top" HorizontalAlignment="Right" Width="30" Background="#00000000" Click="Button_Click_Tag"  ToolTip="タグの内容をコピー" Cursor="Hand">
                        <Path Data="M4.00029 4.08525L4 10.5C4 11.8255 5.03154 12.91 6.33562 12.9947L6.5 13L10.9144 13.0007C10.7083 13.5829 10.1528 14 9.5 14H6C4.34315 14 3 12.6569 3 11V5.5C3 4.84678 3.41754 4.29109 4.00029 4.08525ZM11.5 2C12.3284 2 13 2.67157 13 3.5V10.5C13 11.3284 12.3284 12 11.5 12H6.5C5.67157 12 5 11.3284 5 10.5V3.5C5 2.67157 5.67157 2 6.5 2H11.5ZM11.5 3H6.5C6.22386 3 6 3.22386 6 3.5V10.5C6 10.7761 6.22386 11 6.5 11H11.5C11.7761 11 12 10.7761 12 10.5V3.5C12 3.22386 11.7761 3 11.5 3Z" Fill="#202020" />
                    </Button>
                </Grid>
                <GridSplitter Grid.Row="1" Width="100" Margin="0,5,0,0" HorizontalAlignment="Stretch" Height="5" Cursor="SizeNS"/>
                <ScrollViewer Grid.Row="2" Margin="10,10,10,10">
                    <StackPanel Orientation="Vertical" Name="resultStackPanel" Margin="0,0,0,0" />
                </ScrollViewer>
            </Grid>
        </Grid>
        <local:ProgressAnimation x:Name="progressT" Visibility="Hidden" Background="#51000000" />
        <local:DlProgressDialog x:Name="progressD" Visibility="Collapsed"/>
    </Grid>
</Window>
