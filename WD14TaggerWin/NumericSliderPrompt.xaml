<UserControl x:Class="WD14TaggerWin.NumericSliderPrompt"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:WD14TaggerWin"
             mc:Ignorable="d" Height="36" Width="280">
    <Grid>
        <Label Content="閾値" VerticalContentAlignment="Center" HorizontalAlignment="Left" Width="42" Name="sliderName" />
        <Slider Cursor="Hand" VerticalContentAlignment="Center" ValueChanged="Slider_ValueChanged" MouseWheel="Threshold_MouseWheel" Name="accuracySlider" SmallChange="0.01" Maximum="1" LargeChange="0.1" TickFrequency="0.01" Margin="47,10,65,6" VerticalAlignment="Center"/>
        <TextBox TextWrapping="Wrap" Text="0" Width="60" VerticalContentAlignment="Center" HorizontalContentAlignment="Center" TextChanged="TextBox_TextChanged" x:Name="accuracyTextBox" GotFocus="accuracyTextBox_GotFocus" PreviewMouseLeftButtonDown="accuracyTextBox_PreviewMouseLeftButtonDown" MouseWheel="Threshold_MouseWheel" AllowDrop="True" Cursor="" HorizontalAlignment="Right"/>
    </Grid>
</UserControl>
